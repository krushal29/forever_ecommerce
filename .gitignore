# ============================================================
#  ROOT .gitignore — E-commerce MERN Project
# ============================================================

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Environment Variables (NEVER commit secrets) ─────────────
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
*.env

# ── Build Outputs ─────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
.output/
.vercel/
.netlify/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS / System Files ─────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Editor / IDE ──────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ── Uploaded / Generated Files ────────────────────────────────
uploads/
temp/
tmp/

# ── Testing & Coverage ────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Cache ─────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.vite/

# ── TypeScript / Build Artifacts ──────────────────────────────
*.tsbuildinfo

# ── Package Manager Locks (keep package-lock OR yarn.lock, not both) ──
# Uncomment the one you do NOT use:
# yarn.lock
# package-lock.json

# ── Miscellaneous ─────────────────────────────────────────────
*.pem
*.local
.history/
.husky/_/
