# ============================================================
#  BACKEND .gitignore
# ============================================================

# ── Dependencies ─────────────────────────────────────────────
node_modules/

# ── Environment Variables ─────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# ── Uploaded Files (Multer / Cloudinary staging) ──────────────
uploads/
temp/
tmp/

# ── Build Output ─────────────────────────────────────────────
dist/
build/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Testing / Coverage ────────────────────────────────────────
coverage/
.nyc_output/

# ── Miscellaneous ─────────────────────────────────────────────
*.pem
.history/
